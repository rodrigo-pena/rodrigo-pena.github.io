{
  "name": "rodrigo-pena.github.io",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:css && ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "npm run build:css && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "build:css": "sass --no-source-map src/styles/main.scss public/assets/main.css",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.6.0",
    "astro": "^6.4.6",
    "sass": "^1.93.2"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/cli": "^0.1.14",
    "@playwright/test": "^1.60.0"
  }
}
